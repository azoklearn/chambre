# Copiez ce fichier en ".env" puis renseignez vos clés.

# Clé secrète Stripe (tableau de bord Stripe > Développeurs > Clés API)
# Test : sk_test_...   |   Production : sk_live_...
STRIPE_SECRET_KEY=

# URL publique du site (utilisée pour les redirections après paiement)
BASE_URL=http://localhost:3000

# Port du serveur (optionnel)
PORT=3000
